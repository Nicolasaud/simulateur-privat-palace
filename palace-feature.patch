+    state.crmTodoManual = [];
+  }
+}
+
+export function renderCrmTodoManual() {
+  const root = document.getElementById('crmTodoList');
+  if (!root) return;
+  const items = state.crmTodoManual || [];
+  if (items.length === 0) {
+    root.innerHTML = '<li class="crmTodoEmpty">Aucune note manuelle. Ajoute une tâche au-dessus.</li>';
