+  display: flex; align-items: center; justify-content: space-between; gap: 10px;
+  padding: 8px 12px; border-radius: var(--radius-sm); background: white;
+  border: 1px solid var(--border); transition: opacity 0.2s;
+}
+.crmTodoManualItem label { display: flex; align-items: flex-start; gap: 9px; flex: 1; margin: 0; cursor: pointer; font-weight: 400; font-size: 0.93em; line-height: 1.5; }
+.crmTodoManualItem.done span { text-decoration: line-through; color: var(--text-faded); }
+.crmTodoManualItem.done { opacity: 0.7; background: var(--surface-2); }
+.crmTodoDel {
+  background: transparent; border: none; color: var(--text-faded); font-size: 1.25em;
+  cursor: pointer; padding: 2px 8px; line-height: 1; transition: color 0.15s;
+}
+.crmTodoDel:hover { color: var(--danger); background: transparent; border: none; }
+
+/* ============================================================
+   ACCUEIL — dashboard mois/année
+   ============================================================ */
+.accueilHero { margin-bottom: 24px; }
+.accueilHero h1 { color: var(--primary); font-size: 1.7em; margin-bottom: 6px; }
+
+.accueilBlock {
+  background: white;
+  border: 1px solid var(--border);
+  border-radius: var(--radius-card);
+  padding: 22px 24px;
+  margin-bottom: 18px;
+  box-shadow: var(--shadow-card);
+}
+.accueilBlockHeader { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; gap: 12px; flex-wrap: wrap; }
+.accueilBlockHeader h2 { margin: 0; font-size: 1.35em; color: var(--primary); text-transform: capitalize; }
+.accueilBlockTag {
+  display: inline-block; padding: 4px 12px; background: var(--accent-soft);
+  color: var(--accent); border-radius: 100px; font-size: 0.75em;
+  font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase;
+}
+
+.accueilKpiGrid {
+  display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
+  margin-bottom: 22px;
+}
+.accueilKpiGrid-3 { grid-template-columns: repeat(3, 1fr); }
+@media (max-width: 900px) { .accueilKpiGrid, .accueilKpiGrid-3 { grid-template-columns: repeat(2, 1fr); } }
+@media (max-width: 560px) { .accueilKpiGrid, .accueilKpiGrid-3 { grid-template-columns: 1fr; } }
+
+.accueilKpi {
+  background: var(--surface-2); border: 1px solid var(--border);
+  border-radius: var(--radius-md); padding: 16px 18px;
+  display: flex; flex-direction: column; gap: 6px;
+  transition: border-color 0.15s, transform 0.15s;
+}
+.accueilKpi:hover { border-color: var(--accent); }
+.accueilKpi .lbl {
+  font-size: 0.72em; color: var(--text-muted);
+  text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600;
+  display: flex; align-items: center; justify-content: space-between; gap: 6px;
+}
+.accueilKpi .val {
+  font-size: 1.55em; font-weight: 700; font-family: 'Lexend', sans-serif;
+  color: var(--primary); letter-spacing: -0.02em; line-height: 1.1;
+}
+.accueilKpi .sub { font-size: 0.75em; color: var(--text-faded); font-style: italic; }
+.accueilKpi.accueilObjectif { background: linear-gradient(135deg, var(--accent-soft), white); border-color: rgba(99,102,241,0.25); }
+.accueilKpi.accueilObjectif .val { color: var(--accent); }
+
+.objBtn {
+  background: transparent; border: none; padding: 2px 6px; cursor: pointer;
+  font-size: 0.85em; opacity: 0.7; transition: opacity 0.15s; min-width: auto;
+}
+.objBtn:hover { opacity: 1; background: transparent; }
+
+.accueilProgressWrap { margin-top: 4px; }
+.accueilProgressLabel {
+  display: flex; justify-content: space-between; align-items: baseline;
+  font-size: 0.85em; color: var(--text-muted); margin-bottom: 7px;
+}
+.accueilProgressPct { font-weight: 700; font-size: 1.05em; font-family: 'Lexend', sans-serif; }
+.accueilProgressPct.good   { color: var(--success); }
+.accueilProgressPct.medium { color: var(--warning); }
+.accueilProgressPct.low    { color: var(--danger); }
+
+.accueilProgressBar {
+  width: 100%; height: 10px; background: #e5e7eb;
+  border-radius: 100px; overflow: hidden;
+}
+.accueilProgressFill {
+  height: 100%; border-radius: 100px;
+  transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
+}
+.accueilProgressFill.good   { background: linear-gradient(90deg, #16a34a, #22c55e); }
+.accueilProgressFill.medium { background: linear-gradient(90deg, #d97706, #f59e0b); }
+.accueilProgressFill.low    { background: linear-gradient(90deg, #dc2626, #ef4444); }
