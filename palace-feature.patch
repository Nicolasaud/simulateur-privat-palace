+    renderCrmTable();
+    renderCrmKanban();
+    showToast('Prospect supprimé', 'success', 1500);
+    closeProspectEditor();
+  } catch (e) {
+    if (e.status === 404) {
+      state.crmList = state.crmList.filter(p => p.id !== editingId);
+      renderCrmTable();
+      renderCrmKanban();
