+function statutLabel(id) {
+  return CRM_STATUTS.find(s => s.id === id)?.label || id;
+}
+
+function fmtDate(iso) {
+  if (!iso) return '—';
+  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
+}
